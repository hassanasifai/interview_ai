{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MeetingMind",
  "version": "1.0.0",
  "identifier": "com.meetingmind.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MeetingMind",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "companion",
        "title": "MeetingMind Companion",
        "url": "/?window=companion",
        "width": 520,
        "height": 760,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "MeetingMind Assistant",
        "url": "/?window=overlay",
        "width": 420,
        "height": 760,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": false,
        "visible": false
      },
      {
        "label": "capture-excluded-overlay",
        "title": "MeetingMind - Private Assistant",
        "url": "/?window=capture-excluded-overlay",
        "width": 400,
        "height": 700,
        "x": 50,
        "y": 50,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.groq.com https://api.openai.com https://api.anthropic.com https://api.elevenlabs.io https://drive.google.com https://docs.google.com ipc: http://ipc.localhost asset: http://asset.localhost; img-src 'self' data: blob: asset: http://asset.localhost; media-src 'self' blob: data:; worker-src 'self' blob:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": ["https://example.com/meetingmind/updates/latest.json"],
      "pubkey": "REPLACE_WITH_BASE64_PUBLIC_KEY"
    }
  }
}
