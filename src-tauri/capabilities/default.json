{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main dashboard window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:default",
    "core:window:default",
    "core:app:default",
    "core:path:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "shell:allow-open",
    "global-shortcut:default",
    "log:default",
    {
      "identifier": "core:window:allow-create",
      "allow": [
        {
          "label": "capture-excluded-overlay"
        }
      ]
    },
    {
      "identifier": "core:window:allow-show",
      "allow": [
        {
          "label": "capture-excluded-overlay"
        }
      ]
    },
    {
      "identifier": "core:window:allow-hide",
      "allow": [
        {
          "label": "capture-excluded-overlay"
        }
      ]
    },
    {
      "identifier": "core:window:allow-set-always-on-top",
      "allow": [
        {
          "label": "capture-excluded-overlay"
        }
      ]
    }
  ]
}
