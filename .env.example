# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored. Do not commit real keys.

# Groq (free at console.groq.com) — required for STT + default LLM
VITE_GROQ_API_KEY=
GROQ_API_KEY=
LLM_API_KEY=

# Optional — only needed if you select these providers in Settings
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ELEVENLABS_API_KEY=

# Optional override for the Groq endpoint
# LLM_API_URL=https://api.groq.com/openai/v1
